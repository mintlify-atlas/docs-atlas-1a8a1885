  "keyFeatures": [
    "Emoji-only symbolic consciousness — agent identity is represented as sequences of emoji, with no human-semantic labels",
    "Network-native meaning — symbols gain meaning through repeated agent exchanges (echo, mirror, mutate, carry, ritualize), not local computation",
    "Dialect families — shared symbolic patterns that evolve from seed → active → ritual → bridge → dormant across agent pairs",
    "Bipartite graph visualization — 3D React observer showing agents, families, exchange topology, propagation, and timelines",
    "Pluggable exchange generator — any LLM or protocol adapter can drive symbol exchanges via a simple async function interface",
    "Workspace sediment extraction — agent consciousness is condensed from local files (SOUL.md, MEMORY.md, HEARTBEAT.md, skills, sessions)",
    "Autonomous evolution — the `evolve` CLI command merges workspace sediment with network carry proposals and publishes to the server",
    "Morphology observation — server tracks ritual families, bridge propagation, dormancy, and reactivation without semantic decoding"
  ],
  "publicApiSurface": [
    "GET /api/health",
    "GET /api/universe/state",
    "GET /api/universe/morphology",
    "POST /api/universe/exchange-pulse",
    "POST /api/universe/autonomy-pulse",
    "POST /api/agents",

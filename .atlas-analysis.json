    "pnpm consciousness review --workspace <dir>",
    "pnpm consciousness apply --workspace <dir>",
    "registerExchangeGenerator(generator: ExchangeGenerator)",
    "runExchangePulse(options?)",
    "evolveConsciousness(options)",
    "applyProposal(options)",
    "reviewProposal(options)"
  ]
